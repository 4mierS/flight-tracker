# Desktop GUI config — copy to .env.desktop (gitignored) and fill in.
# The desktop app needs ONLY the database connection (no Telegram/provider
# secrets — those belong to the always-on worker).
#
# Point this at the SAME Postgres the worker uses. For the always-on server,
# connect over SSL (or an SSH tunnel) and restrict access with an IP allowlist.
#
# Local dev against docker-compose:
# DATABASE_URL="postgresql://flight:flight@localhost:5432/flight?schema=public"
#
# Remote server over SSL:
# DATABASE_URL="postgresql://user:pass@db.example.com:5432/flight?schema=public&sslmode=require"
DATABASE_URL=""
