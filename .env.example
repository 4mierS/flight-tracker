# --- Database ---
# Local dev points at the docker-compose postgres; in Coolify use the managed URL.
DATABASE_URL="postgresql://flight:flight@localhost:5432/flight?schema=public"

# --- Travelpayouts Data API ---
# Profile -> API token after joining the affiliate network.
TRAVELPAYOUTS_TOKEN=""
# Optional cache market (e.g. us, uk, ru). Affects which agencies/currency cache you read.
TRAVELPAYOUTS_MARKET="uk"

# --- Telegram (primary alert channel) ---
# Create a bot via @BotFather -> bot token. Get your chat id from @userinfobot.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- Worker behaviour ---
# Every 4 hours on the hour. https://crontab.guru to tweak.
CRON_SCHEDULE="0 */4 * * *"
DEFAULT_CURRENCY="EUR"
# Pause between provider calls to respect rate limits.
PROVIDER_REQUEST_DELAY_MS="400"
